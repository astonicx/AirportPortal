{
  "name": "airportportal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/server.js",
    "build": "vite build",
    "build:full": "vite build && rm -rf server/public && cp -r dist server/public",
    "preview": "vite preview",
    "start": "node server/server.js",
    "lint": "eslint . --ext .js,.jsx --max-warnings=0 || true",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest run --config vitest.config.js --passWithNoTests",
    "test:backend:watch": "vitest --config vitest.config.js --passWithNoTests",
    "test:backend:seeded": "npm run test:db:setup && vitest run --config vitest.config.js --passWithNoTests",
    "test:backend:live": "vitest run --config vitest.config.js --passWithNoTests tests/integration/apiClient.live.test.mjs",
    "test:frontend": "vitest run --config vitest.frontend.config.js --passWithNoTests",
    "test:frontend:watch": "vitest --config vitest.frontend.config.js --passWithNoTests",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "vitest run --config vitest.config.js --coverage --passWithNoTests",
    "test:coverage:frontend": "vitest run --config vitest.frontend.config.js --coverage --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui --pass-with-no-tests",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:server": "mkdir -p tests/.tmp && TEST_DB_PATH=tests/.tmp/e2e.sqlite node tests/db/scripts/setup.mjs && DB_PATH=tests/.tmp/e2e.sqlite NODE_ENV=test SESSION_COOKIE_SECRET=test-session-secret npm run dev",
    "test:db:setup": "node tests/db/scripts/setup.mjs",
    "test:db:reset": "node tests/db/scripts/reset.mjs",
    "test:db:teardown": "node tests/db/scripts/teardown.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "argon2": "^0.44.0",
    "axios": "^1.6.8",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^6.20.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.47",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
