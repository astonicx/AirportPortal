# Client
# Leave blank in dev so requests use relative /api paths and go through the
# Vite proxy (see vite.config.mts). Set to a full origin only for production
# builds that talk to a separately-hosted API.
VITE_API_BASE_URL=

# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:3000
SESSION_COOKIE_SECRET=change-me-in-prod

# BDPA upstream
BEARER_TOKEN=273f841b-4865-48b0-8045-14c768c7ae76
BDPA_BASE_URL=https://airports.api.hscc.bdpa.org

# Root admin seed
ROOT_EMAIL=root@portal.local
ROOT_PASSWORD=ChangeMeImmediately!
