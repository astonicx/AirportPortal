# Client
VITE_API_BASE_URL=http://localhost:5000

# Server
PORT=5000
# Single origin (backward compatible). You can also use CLIENT_ORIGINS for a comma-separated allowlist.
CLIENT_ORIGIN=http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000

# Cookie policy. For cross-origin shared-dev, use:
# SESSION_COOKIE_SAME_SITE=none
# SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SECRET=change-me-in-prod

# BDPA upstream
BEARER_TOKEN=Tobedeterminelater
BDPA_BASE_URL=https://airports.api.hscc.bdpa.org/v2

# Home airport code (optional). Leave blank to auto-derive from the upstream
# arrivals feed (every arrival lands at our airport). Set a code like MWK to
# override.
HOME_AIRPORT=

# Root admin seed
ROOT_EMAIL=root@portal.local
ROOT_PASSWORD=ChangeMeImmediately!
